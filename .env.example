# Copy to .env and fill in. .env is gitignored.
# Environment variables are prefixed BOT_ and nested fields use '__' (double underscore).

# IBKR connection (overrides config.yaml ibkr.* section)
BOT_IBKR__HOST=127.0.0.1
BOT_IBKR__PORT=7497
BOT_IBKR__CLIENT_ID=17

# Path to the YAML file with strategy/risk parameters.
BOT_CONFIG_FILE=config.yaml

# External data sources / notifications (Phase 2+).
BOT_DATA_SOURCES__FINNHUB_API_KEY=          # Finnhub free-tier API key (float + news). Sign up at https://finnhub.io
BOT_DATA_SOURCES__TELEGRAM_BOT_TOKEN=       # Telegram bot token for watchlist pushes. Create via @BotFather on Telegram.
BOT_DATA_SOURCES__TELEGRAM_CHAT_ID=         # Chat ID to receive messages. Message the bot, then hit https://api.telegram.org/bot<TOKEN>/getUpdates to read it.

# Anthropic API key for the Phase 11 LLM exit advisor.
# Required when exit_advisor.enabled=true in config.yaml; ignored otherwise.
# NOT prefixed with BOT_ — the advisor reads it directly from os.environ via
# load_dotenv(), bypassing pydantic-settings. Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Phase 4c rule-based risk tuning (overrides config.yaml risk.* section). Defaults shown.
# BOT_RISK__MAX_POSITION_VALUE_USD=15000        # 3× $5k paper equity; stays under 4:1 margin's $20k ceiling
# BOT_RISK__MAX_STOP_WIDTH_USD=0.50             # the "50¢ is the line I won't cross" rule
# BOT_RISK__MAX_PCT_OF_BAR_VOLUME=2.0           # your order ≪ 2–5% of 1-min volume
# BOT_RISK__EXTENSION_BAR_TRIGGER_MULTIPLE=2.0  # dollar-based extension bar = max_loss × this
